# Email for Let's Encrypt certificate notifications
ACME_EMAIL=you@example.com

# Hostname for the Traefik dashboard
TRAEFIK_DASHBOARD_HOST=dashboard.yourdomain.com

# Basic auth credentials for the Traefik dashboard (htpasswd format)
# Generate with: htpasswd -nb admin yourpassword
# Note: dollar signs do NOT need to be doubled here (that's only needed inline in compose.yml)
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$xxxx$xxxxxxxxxxxxxxxxxxxxxxxx

# Hostname for Uptime Kuma
UPTIME_KUMA_HOST=status.yourdomain.com

# Grafana
GRAFANA_HOST=grafana.yourdomain.com
GRAFANA_ADMIN_PASSWORD=yourpassword
