              { "color": "yellow", "value": 3221225472 },
              { "color": "red", "value": 3758096384 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
